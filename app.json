{
  "expo": {
    "name": "Baby Steps",
    "slug": "baby-steps",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/logo/Profile-pic.png",
    "scheme": "babysteps",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/Profile-pic.png",
        "backgroundColor": "#F8F6F1"
      },
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "package": "com.babysteps.babysteps_prototype"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo/Profile-pic.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
         "fonts": [
            "./assets/fonts/SuperChips.ttf",
            "./assets/fonts/Quicksand-Light.ttf",
            "./assets/fonts/Quicksand-Regular.ttf",
            "./assets/fonts/Quicksand-Medium.ttf",
            "./assets/fonts/Quicksand-SemiBold.ttf",
            "./assets/fonts/Quicksand-Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/Profile-pic.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8C23E"
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0274BB",
          "defaultChannel": "learning-reminders"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Baby Steps adds a coloring picture to Photos only after you tap Save.",
          "granularPermissions": []
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4c0cdf66-5797-49b2-8478-11379264bf1d"
      }
    },
    "owner": "baby-steps"
  }
}
